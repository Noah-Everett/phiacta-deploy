# Stack-level configuration for the Docker Compose dev stack.
#
# Scope: only variables that docker-compose.yml itself reads — project name,
# sibling-repo paths, host-facing ports, and browser-facing URLs.
#
# Service-specific env vars live with each service (single source of truth):
#
#   Backend (phiacta-repo) ..... .env.example → DATABASE_URL, JWT_SECRET_KEY,
#                                                FORGEJO_*, ENVIRONMENT, etc.
#   Web (phiacta-web-repo) ..... .env.example → NEXT_PUBLIC_*, API_URL_INTERNAL
#
# The dev compose hardcodes safe dev defaults for service vars (see
# docker-compose.yml), so a blank .env works out of the box. For prod
# secrets, run ./generate-env.sh <type> to produce a .env.<type> file.
#
# Copy this file to .env and uncomment the lines you want to change.
# For named stacks, create .env.<type> (e.g. .env.prod).

# ── Stack name ─────────────────────────────────────────────────
# COMPOSE_PROJECT_NAME=phiacta

# ── Paths ──────────────────────────────────────────────────────
# Override if your sibling repos have different directory names.
# BACKEND_PATH=../phiacta
# WEB_PATH=../phiacta-web
# VERIFY_PATH=../phiacta-verify

# ── Ports ──────────────────────────────────────────────────────
# Override if defaults conflict with other services on the host.
# FORGEJO_PORT=3000
# WEB_PORT=3001

# ── URLs ───────────────────────────────────────────────────────
# The API URL as the browser sees it. Set to your host IP for remote
# or mobile access, or to the public hostname in prod.
# NEXT_PUBLIC_API_URL=http://localhost:8000

# The canonical public origin of the deployed frontend. Used for
# sitemap, robots.txt, canonical links, and Open Graph tags.
# NEXT_PUBLIC_SITE_URL=https://phiacta.com
