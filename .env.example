# Optional overrides — the default stack works without this file.
#
# Copy to .env and uncomment the lines you want to change.
# For named stacks, you can also create .env.<type> (e.g. .env.prod).

# ── Stack name ─────────────────────────────────────────────────
# COMPOSE_PROJECT_NAME=phiacta

# ── Paths ──────────────────────────────────────────────────────
# Override if your sibling repos have different directory names.
# BACKEND_PATH=../phiacta
# WEB_PATH=../phiacta-web

# ── Ports ──────────────────────────────────────────────────────
# Override if defaults conflict with other services.
# FORGEJO_PORT=3000
# WEB_PORT=3001

# ── URLs ───────────────────────────────────────────────────────
# Set to your host IP for remote/mobile access.
# NEXT_PUBLIC_API_URL=http://localhost:8000
